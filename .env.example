# PostgreSQL (Railway inyecta DATABASE_URL en producción)
DATABASE_URL="postgresql://postgres:postgres@localhost:5544/serycrecer?schema=public"

# Secreto para firmar los JWT (cámbialo en producción)
JWT_SECRET="serycrecer-dev-secret"

# Puerto (Railway inyecta PORT)
PORT=3001

# Orígenes permitidos por CORS (coma-separados; * permite todos)
CORS_ORIGIN="http://localhost:3000"
